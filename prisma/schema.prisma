generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Package {
  id                String   @id @default(cuid())
  name              String
  packageType       String
  uploadDate        DateTime @default(now())
  fileSize          Int
  zipStoragePath    String
  extractedPrefix   String
  entryPointPath    String
  isPublic          Boolean  @default(true)

  @@index([uploadDate])
}
